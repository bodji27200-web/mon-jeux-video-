; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="RPG Tactique Dark Fantasy"
run/main_scene="res://Title.tscn"
config/features=PackedStringArray("4.6")

[autoload]

GameData="*res://GameData.gd"
Audio="*res://Audio.gd"

[display]

window/size/viewport_width=832
window/size/viewport_height=704
window/size/mode=2
window/stretch/mode="canvas_items"
; Web (Xbox/TV 4K) : rendu en 832×704 étiré par l'écran, sinon le GPU du
; navigateur dessine tout en 4K et lâche (« WebGL context lost »).
window/stretch/mode.web="viewport"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.07, 0.07, 0.1, 1)
